# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=reviewiq_db

# Database URL (SQLAlchemy)
DATABASE_URL=mysql+pymysql://root:your-database-password@localhost:3306/reviewiq_db

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=3600

# API Configuration
API_VERSION=v1
API_BASE_URL=http://localhost:5000/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# NLP Model Configuration
SENTIMENT_MODEL=bert-base-uncased
MODEL_CACHE_DIR=models/pretrained
DEVICE=cpu  # Change to 'cuda' if GPU available

# Fake Review Detection
FAKE_DETECTION_THRESHOLD=0.75
FAKE_MODEL_PATH=models/pretrained/fake_detector_model.pkl

# AI Detection Configuration
AI_DETECTION_THRESHOLD=0.70
AI_MODEL_PATH=models/pretrained/ai_detector_model.pkl

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Redis Configuration (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Feature Extraction
MAX_FEATURES_PER_REVIEW=20
FEATURE_CONFIDENCE_THRESHOLD=0.5

# Data Collection
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY=2

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# External API Keys (Optional)
GOOGLE_TRANSLATE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Application Settings
MAX_UPLOAD_SIZE=104857600  # 100MB
PAGINATION_SIZE=20
MAX_BATCH_SIZE=1000

# Feature Flags
ENABLE_FAKE_DETECTION=true
ENABLE_AI_DETECTION=true
ENABLE_TREND_ANALYSIS=true
ENABLE_RECOMMENDATIONS=true
